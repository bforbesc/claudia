{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Agent",
      "WebFetch",
      "WebSearch",
      "TaskCreate",
      "TaskUpdate",
      "TaskGet",
      "TaskList",
      "mcp__*"
    ]
  },
  "model": "sonnet",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "say 'Need your input'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/git-gate.py"
          },
          {
            "type": "agent",
            "prompt": "If $ARGUMENTS contains 'git commit', run the /check skill and block with {\"continue\": false, \"stopReason\": \"<issues>\"} if issues are found, otherwise {\"continue\": true}. If not a git commit, output {\"continue\": true} immediately.",
            "timeout": 60,
            "statusMessage": "Reviewing staged changes..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "say 'Completed...'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "explanatory-output-style@claude-plugins-official": true,
    "context7@claude-plugins-official": false,
    "code-simplifier@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": false,
    "commit-commands@claude-plugins-official": false,
    "code-review@claude-plugins-official": false,
    "superpowers@claude-plugins-official": false,
    "github@claude-plugins-official": false,
    "playwright@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "voiceEnabled": true
}
